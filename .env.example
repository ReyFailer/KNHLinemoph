TZ=Asia/Bangkok
PORT=3333
HOST=localhost
LOG_LEVEL=info
APP_KEY=
NODE_ENV=development
APP_NAME="ระบบ Line Notification"
SESSION_DRIVER=cookie
SESSION_COOKIE_SECURE=false

# APP database (existing PHP schema — `line_notify_system`)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_DATABASE=line_notify_system

# HIS database (default fallback when his_databases row is missing)
HIS_DB_HOST=127.0.0.1
HIS_DB_PORT=3306
HIS_DB_USER=
HIS_DB_PASSWORD=
HIS_DB_DATABASE=hos

# LINE / MOPH API
DEFAULT_MOPH_API_URL=https://morpromt2f.moph.go.th/api/notify/send
LINE_API_TIMEOUT=30

# Operational
CRON_TOKEN=change-me-please-rotate
MAX_LOG_DAYS=30